      </task>
      <task>
        <statement><p>Solve <m>8^{2x}-2(8^x)-8=0</m>.</p></statement>
        <hint><p></p></hint>
        <answer><p></p></answer>
        <solution><p></p></solution>
      </task>
    </exercise>
  </page>
</worksheet>