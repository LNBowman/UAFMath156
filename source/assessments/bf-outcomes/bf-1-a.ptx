<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>BF-1 Solving Quadratic Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete one problem with considerable progress on the other to get P.</p>
  </introduction>  
  <page>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using any method: <m>8(x+3)-3(4x+5)=6x(2x+7)+3</m></p>
      </statement>
    </exercise>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using the quadratic formula: <m>14y-5 = 5y^2 + 10y</m></p>
      </statement>
    </exercise>
  </page>
</worksheet>