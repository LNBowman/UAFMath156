<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
  <title>BF-3 Difference Quotient and Piecewise Functions</title>
  <introduction>
    <p>Complete both problems to earn M. Complete problem 1 and parts a and d of problem 2 to earn P</p>
  </introduction>  
  <page>
    <exercise>
      <statement>
        <p>Given the function <m>f(x)=2x^2-3x</m>.  Find and simplify <m>\frac{f(a)-f(2)}{a-2}</m></p>
      </statement>
    </exercise>
</page>
<page>
    <exercise>
      <introduction><p>Given the piecewise function below, find:</p>
        <p><me>g(x)=\begin{cases} \sqrt{x+4} &amp; -4 \leq x \leq 0 \\ x^3+2 &amp; 0 \lt x \leq 2 \\ 6 &amp; x \gt 2 \end{cases}</me></p></introduction>
      <task workspace="3.5in"><statement><p>Graph the function.</p></statement></task>
      <task workspace="0.5in"><statement><p>State the boundary points.</p></statement></task>
      <task workspace="0.5in"><statement><p>State the intercepts.</p></statement></task>
      <task workspace="0.5in"><statement><p>State the domain in interval notation.</p></statement></task>
    </exercise>
  </page>
</worksheet>