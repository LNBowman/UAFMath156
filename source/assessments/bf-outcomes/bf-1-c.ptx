<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>BF-1 Solving Quadratic Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete one problem with considerable progress on the other to get P.</p>
  </introduction>  
  <page>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using any method: <m>9(x+2)-4(2x-5)=3x(3x+4)-1</m></p>
      </statement>
    </exercise>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using the extraction of roots: <m>2\left(x-\frac{3}{4}\right)^2-9=0</m></p>
      </statement>
    </exercise>
  </page>
</worksheet>