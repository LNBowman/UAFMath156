<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>BF-1 Solving Quadratic Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete one problem with considerable progress on the other to get P.</p>
  </introduction>  
  <page>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using the quadratic formula: <m>15y-2=6y^2+9y</m></p>
      </statement>
    </exercise>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve by factoring: <m>7y^2-8=-26y</m></p>
      </statement>
    </exercise>
  </page>
</worksheet>