<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>EL-2 Exponential and Logarithmic Equations</title>
  <introduction>
    <p>Complete all three problems to get M. Complete two problems with progress on the third to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Solve <m>9^{2x-1} = 27^{x+4}</m>.</p>
    </exercise>
    <exercise workspace="2.5in">
      <p>Solve <m>\log_3(x+4) + \log_3(x-2) = \log_3(7)</m>.</p>
    </exercise>
  </page>
  <page>
<exercise>
  <p>Solve <m>4^x - 6(2^x) + 8 = 0</m></p>
</exercise>
  </page>
</worksheet>