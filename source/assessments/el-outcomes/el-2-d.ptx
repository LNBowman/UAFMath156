<worksheet >
    <title>EL-2 Exponential and Logarithmic Equations</title>
  <introduction>
    <p>Complete all three problems to get M. Complete two problems with progress on the third to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Solve <m>8^{x-2} = \left(\frac{1}{4}\right)^{3x}</m>.</p>
    </exercise>
    <exercise workspace="2.5in">
      <p>Solve <m>\ln(x^2 - 1) = \ln(x) + \ln(3)</m>.</p>
    </exercise>
  </page>
  <page>
<exercise>
  <p>Solve <m>e^{2x} - 5e^x - 6 = 0</m></p>
</exercise>
  </page>
</worksheet>