<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>EL-2 Exponential and Logarithmic Equations</title>
  <introduction>
    <p>Complete all three problems to get M. Complete two problems with progress on the third to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Solve <m>5^{2x+1} = 42</m>.</p>
    </exercise>
    <exercise workspace="2.5in">
      <p>Solve <m>\log_2(x+3) + \log_2(x-3) = 4</m>.</p>
    </exercise>
  </page>
  <page>
<exercise>
  <p>Solve <m>(\log_5 x)^2 - 3\log_5 x - 4 = 0</m></p>
</exercise>
  </page>
</worksheet>