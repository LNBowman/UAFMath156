<worksheet >
    <title>EL-2 Exponential and Logarithmic Equations</title>
  <introduction>
    <p>Complete all three problems to get M. Complete two problems with progress on the third to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Solve <m>2^{3x}=36</m>.</p>
    </exercise>
    <exercise workspace="2.5in">
      <p>Solve <m>\log_2(2-x)+\log_2(x)=\log_2(5)+\log_2(x-2)</m>.</p>
    </exercise>
  </page>
  <page>
<exercise>
  <p>Solve <m>8^{2x}-2(8^x)-8=0</m></p>
</exercise>
  </page>
</worksheet>