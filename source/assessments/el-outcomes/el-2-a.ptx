<worksheet >
    <title>EL-2 Exponential and Logarithmic Equations</title>
  <introduction>
    <p>Complete all both problems to get M. Complete one problem with progress on the other to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Solve <m>2^{3x}=36</m>.</p>
    </exercise>
    <exercise workspace="2.5in">
      <p>Solve <m>\log_2(2-x)+\log_2(x)=\log_2(5)+\log_2(x-2)</m>.</p>
    </exercise>
  </page>
</worksheet>