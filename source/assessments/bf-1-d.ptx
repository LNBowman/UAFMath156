<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>BF-1 Solving Quadratic Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete one problem with considerable progress on the other to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using any method: <m>6(x-5)-3(5x+2)=2x(4x-1)+11</m></p>
      </statement>
    </exercise>
    <exercise workspace="2.5in">
      <statement>
        <p> Solve using the quadratic formula: <m>16y-3=4y^2+6y</m></p>
      </statement>
    </exercise>
  </page>
</worksheet>
