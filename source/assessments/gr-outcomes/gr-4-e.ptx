<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>GR-4 Systems of Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete one problem with progress on the other to get P.</p>
  </introduction>
  <page>
    <exercise workspace="3in">
      <statement><p>Solve the system of equations:<md>\begin{cases} x+y+z=6\\2x-y+3z=9\\3x+4z=15 \end{cases}</md></p></statement>
    </exercise>
    <exercise workspace="2in">
      <statement><p>Solve the system of equations:<md>\begin{cases} x^2+y^2=8\\xy=4 \end{cases}</md></p></statement>
    </exercise>
  </page>
</worksheet>