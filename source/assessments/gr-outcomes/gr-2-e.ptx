<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>GR-2 Graphing Polynomials</title>
  <introduction>
    <p>Complete all parts to get M. Complete any three parts to get P.</p>
  </introduction>
  <page>
    <exercise>
      <introduction><p>Given the polynomial <m>p(x)=3x^4+18x^3+15x^2-48x+48</m></p></introduction>
      <task workspace="0.5in"><statement><p>State the end behavior of the function, using correct notation.</p></statement></task>
      <task workspace="0.5in"><statement><p>State the <m>y</m>-intercept of the function.</p></statement></task>
      <task workspace="2in"><statement><p>State the zeros and their multiplicities.</p></statement></task>
      <task workspace="2in"><statement><p>Provide a complete graph of the function.</p></statement></task>
    </exercise>
  </page>
</worksheet>