<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>TF-1 Right Triangle Trigonometry</title>
  <introduction>
    <p>Complete both problems to get M. Complete four parts of problem 1 and give the complete diagram for problem 2 to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Find all six trigonometric values of <m>\theta</m></p>
      <image width="50%">
              <prefigure xmlns="https://prefigure.org"
                          label="prefigure-tf1-d">
                  <coordinates bbox="(-5,-5,5,5)">
                    <polygon points="((-2,-3),(-2,2),(1,-3))" closed="yes" stroke="blue"/>
                    <polygon points="((-1.75,-3),(-1.75,-2.75),(-2,-2.75))" stroke="blue"/>
                    <angle-marker points="((-2,-3),(-2,2),(1,-3))" stroke="blue">
                      <m>\theta</m>
                    </angle-marker>
                    <label p="(-2,-3)" alignment="sw" ><m>D</m></label>
                    <label p="(-2,2)" alignment="nw" ><m>E</m></label>
                    <label p="(1,-3)" alignment="se" ><m>F</m></label>
                    <label p="(-2,-0.5)" alignment="w" ><m>7</m></label>
                    <label p="(-0.5,-0.5)" alignment="ne" ><m>10</m></label>
                  </coordinates>
              </prefigure>
            </image>
    </exercise>
  </page>
  <page>
<exercise workspace="2.5in">
  <p>A pilot flying an airplane at an altitude of 8,500 feet sights an airport runway ahead. 
    The angle of depression from the plane to the runway is <m>14^\circ</m>. Draw a picture 
    to model this situation and give the simplified expression that gives the direct line-of-sight 
    distance from the plane to the runway.</p>
</exercise>
  </page>
</worksheet>