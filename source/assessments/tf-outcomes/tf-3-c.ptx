<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>TF-3 Trigonometric Equations</title>
  <introduction>
    <p>Complete both problems to get M. Complete problem 1 with progress on problem 2 to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Find all solutions to the trigonometric equation:</p>
      <p><m>\sec^2(x) - 2\tan(x) = 4</m></p>
    </exercise>

    <exercise workspace="2.5in">
      <p>Solve the trigonometric equation on the interval <m>[0, 2\pi]</m>:</p>
      <p><m>\sin^2\left(\frac{x}{2}\right) = \cos(x)</m></p>
    </exercise>
  </page>
</worksheet>