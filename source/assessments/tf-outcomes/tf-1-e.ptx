<?xml version="1.0" encoding="UTF-8"?>

<worksheet >
    <title>TF-1 Right Triangle Trigonometry</title>
  <introduction>
    <p>Complete both problems to get M. Complete four parts of problem 1 and give the complete diagram for problem 2 to get P.</p>
  </introduction>
  <page>
    <exercise workspace="2.5in">
      <p>Find all six trigonometric values of <m>\theta</m></p>
      <image width="50%">
              <prefigure xmlns="https://prefigure.org"
                          label="prefigure-tf1-e">
                  <coordinates bbox="(-5,-5,5,5)">
                    <polygon points="((-3,-1),(-1,2),(4,-1))" closed="yes" stroke="blue"/>
                    <polygon points="((-1.25,1.625),(-1,1.5),(-0.75,1.85))" stroke="blue"/>
                    <angle-marker points="((-1,2),(4,-1),(-3,-1))" stroke="blue">
                      <m>\theta</m>
                    </angle-marker>
                    <label p="(-3,-1)" alignment="w" ><m>A</m></label>
                    <label p="(4,-1)" alignment="e" ><m>B</m></label>
                    <label p="(-1,2)" alignment="n" ><m>C</m></label>
                    <label p="(1.5,0.5)" alignment="e" ><m>14</m></label>
                    <label p="(0,-1)" alignment="s" ><m>20</m></label>
                  </coordinates>
              </prefigure>
            </image>
    </exercise>
  </page>
  <page>
<exercise workspace="2.5in">
  <p>A person is standing on the ground looking up at a bird nested on top of a 40-foot flagpole. The 
    angle of elevation from the person's eyes to the bird is <m>53^\circ</m>. Draw a picture to model 
    this situation and give the simplified expression that gives the straight-line distance from the 
    person's feet to the base of the flagpole.</p>
</exercise>
  </page>
</worksheet>