<?xml version="1.0" encoding="UTF-8"?>

<worksheet>
  <title>BF-1 Linear and Quadratic Equations</title>
  <introduction>
    <p>
      <alert>Instructions:</alert> Once you open the quiz, your timer begins.  
      I would recommend having an additional timer that goes off about 5 
      minutes prior, so that you know when to start uploading your work.
    </p>
    <p> Write out complete solutions to the following problems.</p>
  </introduction>

  <page>
    <exercise workspace="3cm">
      <statement>
        <p>
          Solve the following equation: <m>|3x-4|=x+5</m> 
        </p>
      </statement>
    </exercise>
    <exercise workspace="3cm">
      <statement>
        <p>Solve <m>6x^2-x=1</m> by factoring.</p>
      </statement>
    </exercise>
    <exercise workspace="3cm">
      <statement>
        <p>Solve <m>9x^2-12x-1=0</m> using the quadratic formula.</p>
      </statement>
    </exercise>
  </page>
</worksheet>
